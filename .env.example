# docker-compose environment for the Patient Care stack.
# Copy to .env and fill in real values:  cp .env.example .env
# NEVER commit .env. (When deploying with Dokploy you set these in the UI instead.)

# --- Postgres ---
# POSTGRES_PASSWORD must match the password embedded in DATABASE_URL below.
POSTGRES_PASSWORD=change-me-to-a-strong-db-password
POSTGRES_DB=patient_care

# --- Backend ---
# Async driver + the `postgres` compose service hostname. If you set
# POSTGRES_PASSWORD above and leave this unset, compose composes it for you;
# set it explicitly only if you want a non-default user/db.
DATABASE_URL=postgresql+asyncpg://postgres:change-me-to-a-strong-db-password@postgres:5432/patient_care

# Long random string. Generate one with:  openssl rand -hex 32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# Bootstrap admin — created on first startup if no admin exists (main.py).
BOOTSTRAP_ADMIN_EMAIL=admin@patient.care
BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-admin-password

# Firebase service-account JSON as a SINGLE LINE. Leave empty to bring the stack
# up without push (the app still works; FCM sends are skipped and logged).
# Paste the whole {...} on one line when you're ready to enable nurse push.
FIREBASE_CREDS_JSON=
