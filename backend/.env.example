# Copy to .env and fill in real values. Never commit .env.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/patient_care
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=60
REFRESH_TOKEN_TTL_DAYS=14
WS_TICKET_TTL_SEC=60
DEVICE_TOKEN_TTL_DAYS=365

# Firebase service account JSON, single-line. Produce it with:  jq -c . serviceAccount.json
# The backend runs json.loads() on this directly (raw JSON, NOT base64).
# Leave blank during early dev; FCM send will be skipped. See FIREBASE_SETUP.md.
FIREBASE_CREDS_JSON=

# Bootstrap admin (created on first startup if no admin exists)
BOOTSTRAP_ADMIN_EMAIL=admin@patient.care
BOOTSTRAP_ADMIN_PASSWORD=Test1234!
