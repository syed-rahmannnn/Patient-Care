# Copy to .env. NEVER commit .env.

BACKEND_URL=http://localhost:8000
DEVICE_TOKEN=                       # long-lived JWT from POST /rooms/{id}/devices
SERIAL_PORT=/dev/tty.usbmodem1101   # macOS example; on Linux: /dev/ttyUSB0 or /dev/ttyACM0
BAUD=9600
SPEECH_RATE=155                     # for `say` on macOS / espeak on Linux
